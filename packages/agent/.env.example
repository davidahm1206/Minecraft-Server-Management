# ─── MCPanel Agent Configuration ───
# Copy this file to .env and fill in your values

# ─── Required ───
# WebSocket URL of your deployed Cloudflare Worker
WORKER_WS_URL=wss://your-worker.workers.dev/ws

# Shared secret between agent and worker (set in wrangler secrets too)
AGENT_TOKEN=change-me-strong-random-token

# Absolute path to your Fabric server directory
MC_SERVER_DIR=/opt/minecraft/fabric-1.21.1

# ─── Launch Mode ───
# 'jar'    → java -jar fabric-server-launch.jar nogui  (default, simpler)
# 'script' → bash run.sh  (use if server was set up via Fabric installer)
MC_LAUNCH_MODE=jar

# JAR filename for jar mode (Fabric dedicated server launcher)
# Download from: https://fabricmc.net/use/server/
MC_JAR=fabric-server-launch.jar

# Script filename for script mode (generated by Fabric installer)
MC_RUN_SCRIPT=run.sh

# ─── Java ───
# Leave blank to auto-detect (Java 21+ is required for Minecraft 1.21.1)
JAVA_PATH=

# ─── JVM Memory ───
# Fabric 1.21.1 recommended: minimum 4G, optimal 6-8G
MC_MIN_RAM=4G
MC_MAX_RAM=8G

# ─── JVM Flags ───
# Aikar's flags, tuned for Java 21 + Fabric 1.21.1
# -Dfabric.skipMcProvider=true disables Mojang auth provider check in server mode
MC_JVM_ARGS=-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1HeapWastePercent=5 -XX:G1MixedGCCountTarget=4 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1RSetUpdatingPauseTimePercent=5 -XX:SurvivorRatio=32 -XX:+PerfDisableSharedMem -XX:MaxTenuringThreshold=1 -Dfabric.skipMcProvider=true

# ─── Logging ───
LOG_LEVEL=info
