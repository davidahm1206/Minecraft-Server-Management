# Agent WebSocket URL (Cloudflare Worker)
WORKER_WS_URL=wss://mcpanel-worker.your-subdomain.workers.dev/ws

# Agent token (must match the AGENT_TOKEN secret in the Worker)
AGENT_TOKEN=your-agent-token-here

# Minecraft server directory (absolute path)
MC_SERVER_DIR=/home/minecraft/server

# Java executable path (leave empty for auto-detect)
JAVA_PATH=

# Minecraft server JAR filename
MC_JAR=server.jar

# JVM memory settings
MC_MIN_RAM=2G
MC_MAX_RAM=4G

# Extra JVM arguments
MC_JVM_ARGS=-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200

# Log level
LOG_LEVEL=info
