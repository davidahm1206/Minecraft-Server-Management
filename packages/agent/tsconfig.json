{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": ".",
    "outDir": "dist",

    "baseUrl": ".",

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "strict": false
  },

  "include": [
    "src",
    "../shared/src"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}