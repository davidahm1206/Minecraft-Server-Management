{
  "name": "@mcpanel/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply mcpanel-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply mcpanel-db --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "zod": "^3.24.0",
    "@mcpanel/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
