# JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET=your-secret-key-here

# Agent Token (generate: openssl rand -hex 32)
AGENT_TOKEN=your-agent-token-here

# Admin credentials (initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Worker URL (for agent connection)
WORKER_WS_URL=wss://your-worker.your-subdomain.workers.dev/ws

# Minecraft server directory (agent only)
MC_SERVER_DIR=/home/minecraft/server

# Java path (agent only, leave empty for auto-detect)
JAVA_PATH=
